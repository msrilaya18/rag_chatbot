# === RAG Video Chatbot Environment Variables ===

# Google Gemini API Key (get free at https://aistudio.google.com/apikey)
# Used for both LLM (Gemini 2.0 Flash) and Embeddings (text-embedding-004)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key (if you want OpenAI embeddings instead of Gemini)
# OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB settings (local by default)
CHROMA_PERSIST_DIR=./chroma_data

# App settings
BACKEND_PORT=8000
FRONTEND_PORT=3000
